<UserControl x:Class="SnowyRiver.WPF.MaterialDesignInPrism.Controls.PasswordFieldEditor"
                          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:prism="http://prismlibrary.com/"
                          xmlns:controls="clr-namespace:SnowyRiver.WPF.MaterialDesignInPrism.Controls"
                          xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                          prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"
                   Style="{Binding HeaderStyle, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"/>
        <PasswordBox Grid.Column="1" 
                 mah:PasswordBoxBindingBehavior.Password="{Binding Value, 
                        RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor},
                        UpdateSourceTrigger=PropertyChanged}"
                 Style="{Binding ValueStyle, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"
                 IsEnabled="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"/>
        <TextBlock Grid.Column="2" Text="{Binding Unit, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"
                   Style="{Binding UnitStyle, RelativeSource={RelativeSource AncestorType=controls:PasswordFieldEditor}}"/>
    </Grid>
</UserControl>
