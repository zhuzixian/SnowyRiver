<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SnowyRiver.Styles.Dialog.Title" TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
    </Style>

    <Style x:Key="SnowyRiver.Styles.Dialog.Button" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Margin" Value="12, 0"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark.Foreground}"/>
    </Style>
</ResourceDictionary>