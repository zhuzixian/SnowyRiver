<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SnowyRiver.WPF.MaterialDesignInPrism.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <materialDesign:NotConverter x:Key="NotConverter" />

    <Style TargetType="{x:Type controls:TextFieldEditor}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TextFieldEditor}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding HeaderSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding UnitSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Margin="4,0"
                            VerticalAlignment="{TemplateBinding HeaderVerticalAlignment}"
                            Style="{TemplateBinding HeaderStyle}"
                            Text="{TemplateBinding Header}" />

                        <TextBox
                            x:Name="PART_TextBox"
                            Grid.Column="1"
                            Margin="4,0"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            IsReadOnly="{TemplateBinding IsReadOnly}"
                            MaxLength="{TemplateBinding MaxLength}"
                            MaxLines="{TemplateBinding MaxLines}"
                            MinLines="{TemplateBinding MinLines}"
                            Style="{TemplateBinding ValueStyle}"
                            Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TextAlignment="{TemplateBinding TextAlignment}"
                            TextWrapping="{TemplateBinding TextWrapping}" />

                        <TextBlock
                            Grid.Column="2"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Style="{TemplateBinding UnitStyle}"
                            Text="{TemplateBinding Unit}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:PasswordFieldEditor}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PasswordFieldEditor}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding HeaderSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding UnitSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Margin="4,0"
                            VerticalAlignment="{TemplateBinding HeaderVerticalAlignment}"
                            Style="{TemplateBinding HeaderStyle}"
                            Text="{TemplateBinding Header}" />

                        <PasswordBox
                            x:Name="PART_PasswordBox"
                            Grid.Column="1"
                            Margin="4,0"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            IsEnabled="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NotConverter}}"
                            Style="{TemplateBinding ValueStyle}" />

                        <TextBlock
                            Grid.Column="2"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Style="{TemplateBinding UnitStyle}"
                            Text="{TemplateBinding Unit}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:ComboBoxFieldEditor}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ComboBoxFieldEditor}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding HeaderSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="{Binding UnitSizeGroup, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Margin="4,0"
                            VerticalAlignment="{TemplateBinding HeaderVerticalAlignment}"
                            Style="{TemplateBinding HeaderStyle}"
                            Text="{TemplateBinding Header}" />

                        <ComboBox
                            x:Name="PART_ComboBox"
                            Grid.Column="1"
                            Margin="4,0"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            DisplayMemberPath="{TemplateBinding DisplayMemberPath}"
                            IsEnabled="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource InverseBooleanConverter}}"
                            ItemsSource="{TemplateBinding ItemsSource}"
                            SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="{TemplateBinding SelectedValuePath}"
                            Style="{TemplateBinding ValueStyle}" />

                        <TextBlock
                            Grid.Column="2"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Style="{TemplateBinding UnitStyle}"
                            Text="{TemplateBinding Unit}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:ToolBarIcoTextButton}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="TextBlock.FontWeight" Value="DemiBold" />
        <Setter Property="materialDesign:RippleAssist.Feedback" Value="{DynamicResource MaterialDesign.Brush.Button.Ripple}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToolBarIcoTextButton}">
                    <Border
                        x:Name="border"
                        Background="Transparent"
                        CornerRadius="2">
                        <materialDesign:Ripple
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Feedback="{TemplateBinding Foreground}"
                            Focusable="False"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="{TemplateBinding Kind}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{TemplateBinding Text}" />
                            </StackPanel>
                        </materialDesign:Ripple>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Opacity" Value=".56" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource MaterialDesign.Brush.Button.FlatClick}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Button.FlatClick}" />
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Static system:String.Empty}">
                            <Setter TargetName="PART_Text" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>